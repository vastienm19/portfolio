<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VASTIENM</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Cormorant+Garamond:italic,wght@400&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: #000; color: #fff; font-family: 'Cormorant Garamond', serif; overflow-x: hidden; }

        /* LOGO FIJO ARRIBA */
        header {
            position: fixed;
            top: 0; width: 100%; height: 120px;
            display: flex; align-items: center; justify-content: center;
            z-index: 1000; background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
        }
        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 2.5rem;
            color: #FFD700;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        /* CADA SECCIÓN OCUPA TODA LA PANTALLA */
        section {
            height: 100vh;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            position: relative; text-align: center;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
        }

        .bg-foto {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; opacity: 0.4; z-index: -1;
        }

        /* TEXTOS GIGANTES */
        .servicio-titulo {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3.5rem, 12vw, 8rem);
            color: #FFD700;
            text-decoration: none;
            text-transform: uppercase;
            line-height: 0.8;
        }

        .sub-tag {
            font-size: 1.2rem;
            letter-spacing: 6px;
            text-transform: uppercase;
            margin-top: 20px;
            opacity: 0.8;
        }

        /* SECCIÓN ABOUT ME */
        .about-box { max-width: 800px; padding: 40px; font-size: 2rem; font-style: italic; line-height: 1.3; }

        /* BOTÓN WHATSAPP */
        .btn-ws {
            font-family: 'Syne', sans-serif;
            color: #FFD700; border: 1px solid #FFD700;
            padding: 20px 50px; text-decoration: none;
            letter-spacing: 3px; margin-top: 30px;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-text">VASTIENM</div>
    </header>

    <section>
        <img src="filmaker.jpg" class="bg-foto">
        <a href="filmmaker.html" class="servicio-titulo">Filmmaker</a>
        <p class="sub-tag">Visual Storytelling</p>
    </section>

    <section>
        <img src="edicion.png" class="bg-foto">
        <a href="edicion.html" class="servicio-titulo">Edición</a>
        <p class="sub-tag">Narrativa & Color</p>
    </section>

    <section>
        <img src="drone.jpg" class="bg-foto">
        <a href="drone.html" class="servicio-titulo">Drone</a>
        <p class="sub-tag">Perspectiva Aérea</p>
    </section>

    <section>
        <div class="about-box">
            Soy Sebastian, filmmaker y editor. Busco la calidad estética y la potencia visual en cada proyecto.
        </div>
    </section>

    <section>
        <a href="https://wa.me/5491100000000" class="btn-ws">WHATSAPP</a>
    </section>

</body>
</html> 
