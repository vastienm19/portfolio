<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VASTIENM</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Cormorant+Garamond:italic,wght@400&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: #000; color: #fff; font-family: 'Cormorant Garamond', serif; overflow-x: hidden; }

        header {
            position: fixed;
            top: 40px; width: 100%;
            z-index: 1000;
            text-align: center;
        }
        .logo { font-family: 'Syne', sans-serif; font-size: 2.5rem; color: #FFD700; text-transform: uppercase; }

        section {
            height: 100vh;
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            text-align: center;
        }

        .bg-img {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; opacity: 0.4; z-index: -1;
        }

        .main-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(4rem, 15vw, 9rem);
            color: #FFD700;
            text-transform: uppercase;
            text-decoration: none;
            line-height: 0.8;
        }

        .sub-tag {
            font-size: 1.4rem;
            letter-spacing: 10px;
            text-transform: uppercase;
            margin-top: 20px;
            opacity: 0.8;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">VASTIENM</div>
    </header>

    <section>
        <img src="filmaker.jpg" class="bg-img">
        <a href="filmmaker.html" class="main-title">FILMMAKER</a>
        <p class="sub-tag">STORYTELLING VISUAL</p>
    </section>

</body>
</html>
